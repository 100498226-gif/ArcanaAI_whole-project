# =============================================================================
# Arcana — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values.
# Never commit .env to version control.
#
# Variables are grouped by phase. Those marked (REQUIRED) must be set before
# the server will start correctly. Those marked (OPTIONAL) have sane defaults.
# Those marked (FUTURE) are placeholders for upcoming phases — leave blank
# or commented out until that phase is implemented.
# =============================================================================


# ─── Phase 1: Core Scaffold ───────────────────────────────────────────────────

# Runtime environment. Controls logging verbosity and behaviour.
# Values: development | testing | production
APP_ENV=development                                              # (REQUIRED)

# Secret key used to sign internal tokens and session data.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
APP_SECRET_KEY=change-me                                        # (REQUIRED)

# SQLAlchemy async database URL.
# SQLite (dev/thesis — zero infrastructure):
DATABASE_URL=sqlite+aiosqlite:///./data/arcana.db               # (REQUIRED)
# PostgreSQL (production — swap the line above for this one):
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/arcana

# Filesystem path where ChromaDB stores its vector index.
# For production, point this to a persistent volume.
CHROMADB_PATH=./data/chromadb                                   # (REQUIRED)

# Verbosity of structured JSON logs emitted to stdout.
# Values: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO                                                   # (OPTIONAL)

# Comma-separated list of allowed CORS origins, or * to allow all.
# Tighten this in production (e.g. https://your-internal-tool.com).
CORS_ORIGINS=*                                                   # (OPTIONAL)


# ─── Phase 1: Embeddings ─────────────────────────────────────────────────────

# Which embedding provider to use when vectorising chunks.
# Values: google | openai | voyage
EMBEDDING_PROVIDER=google                                        # (REQUIRED)

# Embedding model name for the chosen provider.
# Google: gemini-embedding-001
# OpenAI: text-embedding-3-small
# Voyage: voyage-code-2
EMBEDDING_MODEL=gemini-embedding-001                            # (REQUIRED)

# API key override for the embedding provider.
# Leave blank to reuse GOOGLE_VERTEX_API_KEY automatically.
EMBEDDING_API_KEY=                                               # (OPTIONAL)


# ─── Phase 1: AI — Gemini ────────────────────────────────────────────────────

# Google AI Studio API key — used for both LLM (Gemini) and embeddings.
# Get one at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_api_key_here                                # (REQUIRED)

# Gemini model used for LLM answers. Default: gemini-2.0-flash
GEMINI_MODEL=gemini-2.0-flash                                   # (OPTIONAL)


# ─── Phase 2: GitHub Ingestion ───────────────────────────────────────────────

# GitHub Personal Access Token with repo + read:org scopes.
# Never stored in the database — lives here only.
# Create one at: https://github.com/settings/tokens
GITHUB_PAT=ghp_your_token_here                                  # (REQUIRED for Phase 2)

# Comma-separated list of repositories to ingest via `make bootstrap`.
# Format: owner/repo — e.g. "acme/backend,acme/frontend"
GITHUB_REPOS=                                                    # (OPTIONAL — used by bootstrap)


# ─── Phase 3: Notion Ingestion ───────────────────────────────────────────────

# Notion internal integration token.
# Create an integration at: https://www.notion.so/my-integrations
# Then share the pages you want indexed with the integration.
NOTION_TOKEN=secret_your_notion_token_here                      # (REQUIRED for Phase 3)

# Comma-separated Notion page IDs to ingest via `make bootstrap`.
# Find the page ID in the Notion URL: notion.so/<workspace>/<PAGE_ID>
NOTION_PAGE_IDS=                                                 # (OPTIONAL — used by bootstrap)

# How often (in hours) the daily sync job re-checks Notion for changes.
# Default is 24 (once per day). Set to 1 for near-hourly refreshes.
NOTION_SYNC_INTERVAL_HOURS=24                                   # (OPTIONAL)

# Maximum page nesting depth to traverse. Pages deeper than this are skipped.
# Default 5 covers the vast majority of real-world Notion workspaces.
NOTION_MAX_DEPTH=5                                              # (OPTIONAL)

# Milliseconds to wait between Notion API calls (rate limit: 3 req/s).
# Default 350ms keeps us safely under the limit.
NOTION_REQUEST_DELAY_MS=350                                     # (OPTIONAL)


# ─── Phase 4: RBAC (FUTURE) ──────────────────────────────────────────────────

# No new environment variables anticipated for Phase 4. RBAC logic will use
# the access_scope metadata already stored on every chunk and the existing
# user/role model in the database.


# ─── Phase 5: AI Orchestration (FUTURE) ──────────────────────────────────────

# Gemini model used for answering developer questions.
# Leave blank to use the default model defined in code.
# Example: gemini-2.0-flash
# GEMINI_CHAT_MODEL=                                            # (FUTURE)

# Number of chunks retrieved from ChromaDB per query (retrieval top-k).
# Higher values give richer context but increase token usage and latency.
# RETRIEVAL_TOP_K=10                                            # (FUTURE)

# Maximum tokens allowed in the LLM context window per request.
# RETRIEVAL_MAX_CONTEXT_TOKENS=8000                             # (FUTURE)


# ─── Phase 6: Cursor Extension / CLI (FUTURE) ────────────────────────────────

# Base URL of the running Arcana server, used by the Cursor extension and CLI
# to know where to send queries.
# ARCANA_API_URL=http://localhost:8000                          # (FUTURE)
